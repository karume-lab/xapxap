{
  "name": "xapxap",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "expo prebuild --clean",
    "dev": "NODE_OPTIONS='--no-deprecation' expo start",
    "start": "NODE_OPTIONS='--no-deprecation' expo start --go",
    "android": "NODE_OPTIONS='--no-deprecation' expo prebuild --clean && NODE_OPTIONS='--no-deprecation' expo run:android",
    "build": "NODE_OPTIONS='--no-deprecation' expo prebuild --clean && ./android/gradlew -p android assembleRelease && mv ./android/app/build/outputs/apk/release/app-release.apk ./android/app/build/outputs/apk/release/xapxap.apk",
    "install-apk": "adb install ./android/app/build/outputs/apk/release/xapxap.apk",
    "build:install-apk": "bun run build && bun run install-apk",
    "doctor": "NODE_OPTIONS='--no-deprecation' expo-doctor --verbose",
    "update-packages": "expo install --check",
    "reinstall-packages": "rm -rf node_modules bun.lock && bun i",
    "lint": "biome check",
    "format": "biome format",
    "check": "biome check",
    "clean": "biome check --write",
    "typecheck": "tsc --noEmit",
    "ios": "NODE_OPTIONS='--no-deprecation' expo run:ios"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@gorhom/bottom-sheet": "^5.2.14",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@rn-primitives/accordion": "^1.4.0",
    "@rn-primitives/alert-dialog": "^1.4.0",
    "@rn-primitives/aspect-ratio": "^1.4.0",
    "@rn-primitives/avatar": "^1.4.0",
    "@rn-primitives/checkbox": "^1.4.0",
    "@rn-primitives/collapsible": "^1.4.0",
    "@rn-primitives/context-menu": "^1.4.0",
    "@rn-primitives/dialog": "^1.4.0",
    "@rn-primitives/dropdown-menu": "^1.4.0",
    "@rn-primitives/hover-card": "^1.4.0",
    "@rn-primitives/label": "^1.4.0",
    "@rn-primitives/menubar": "^1.4.0",
    "@rn-primitives/popover": "^1.4.0",
    "@rn-primitives/portal": "~1.4.0",
    "@rn-primitives/progress": "^1.4.0",
    "@rn-primitives/radio-group": "^1.4.0",
    "@rn-primitives/select": "^1.4.0",
    "@rn-primitives/separator": "^1.4.0",
    "@rn-primitives/slot": "^1.4.0",
    "@rn-primitives/switch": "^1.4.0",
    "@rn-primitives/tabs": "^1.4.0",
    "@rn-primitives/toggle": "^1.4.0",
    "@rn-primitives/toggle-group": "^1.4.0",
    "@rn-primitives/tooltip": "^1.4.0",
    "@supabase/supabase-js": "^2.105.4",
    "@tanstack/react-query": "^5.100.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "expo": "^56.0.12",
    "expo-blur": "~56.0.3",
    "expo-build-properties": "^56.0.19",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-image-picker": "~56.0.18",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "expo-video": "~56.1.4",
    "lucide-react-native": "^1.14.0",
    "react": "19.2.3",
    "react-hook-form": "^7.75.0",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "uniwind": "^1.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@biomejs/biome": "^2.4.15",
    "@types/react": "~19.2.10",
    "drizzle-kit": "^0.31.10",
    "expo-dev-client": "~56.0.20",
    "expo-doctor": "^1.18.22",
    "lefthook": "^2.1.6",
    "typescript": "~6.0.3"
  },
  "private": true
}
